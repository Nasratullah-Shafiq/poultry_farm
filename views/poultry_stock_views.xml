<odoo>
    <!-- =========================
         Poultry Stock Tree Views
         Three views: Medicine, Chicken, Food
    ========================= -->

    <!-- Medicine Stock Tree View -->
    <record id="view_poultry_stock_medicine_tree" model="ir.ui.view">
        <field name="name">poultry.stock.medicine.tree</field>
        <field name="model">poultry.stock</field>
        <field name="arch" type="xml">
            <tree string="Medicine Stock" create="false" edit="false">
                <field name="branch_id"/>
                <field name="farm_id"/>
                <field name="product_id"/>
                <field name="uom_id"/>
                <field name="total_quantity"/>
                <field name="cost"/>
                <field name="cost_amount"/>
                <field name="currency_id"/>
                <field name="last_updated" readonly="1"/>
            </tree>
        </field>
    </record>

    <!-- Chicken Stock Tree View -->
    <record id="view_poultry_stock_chicken_tree" model="ir.ui.view">
        <field name="name">poultry.stock.chicken.tree</field>
        <field name="model">poultry.stock</field>
        <field name="arch" type="xml">
            <tree string="Chicken Stock" create="false" edit="false">
                <field name="branch_id"/>
                <field name="farm_id"/>
                <field name="product_id"/>
                <field name="uom_id"/>
                <field name="total_quantity"/>
                <field name="cost"/>
                <field name="cost_amount"/>
                <field name="currency_id"/>
                <field name="last_updated" readonly="1"/>
            </tree>
        </field>
    </record>

    <!-- Food Stock Tree View -->
    <record id="view_poultry_stock_food_tree" model="ir.ui.view">
        <field name="name">poultry.stock.food.tree</field>
        <field name="model">poultry.stock</field>
        <field name="arch" type="xml">
            <tree string="Food Stock" create="false" edit="false">
                <field name="branch_id"/>
                <field name="farm_id"/>
                <field name="product_id"/>
                <field name="uom_id"/>
                <field name="total_quantity"/>
                <field name="cost"/>
                <field name="cost_amount"/>
                <field name="currency_id"/>
                <field name="last_updated" readonly="1"/>
            </tree>
        </field>
    </record>

     <!-- =========================
         Search Panel (shared for all menus)
    ========================= -->
    <record id="view_poultry_stock_search" model="ir.ui.view">
        <field name="name">poultry.stock.search</field>
        <field name="model">poultry.stock</field>
        <field name="arch" type="xml">
            <search string="Search Stock">
                <field name="branch_id"/>
                <field name="farm_id"/>
                <field name="product_id"/>
                <searchpanel>
                    <field name="branch_id" string="Branch" icon="fa-sitemap"/>
                    <field name="farm_id" string="Farm House" icon="fa-home"/>
                    <field name="product_id" string="Product" icon="fa-tags"/>
                </searchpanel>
            </search>
        </field>
    </record>


    <!-- =========================
         Actions filtered by product_type
    ========================= -->

    <!-- Medicine Stock Action -->
    <record id="action_poultry_medicine" model="ir.actions.act_window">
        <field name="name">Medicine Stock</field>
        <field name="res_model">poultry.stock</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_poultry_stock_medicine_tree"/>
        <field name="domain">[('product_id.product_type','=','medicine')]</field>
    </record>

    <!-- Chicken Stock Action -->
    <record id="action_poultry_chicken" model="ir.actions.act_window">
        <field name="name">Chicken Stock</field>
        <field name="res_model">poultry.stock</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_poultry_stock_chicken_tree"/>
        <field name="domain">[('product_id.product_type','=','chicken')]</field>
    </record>

    <!-- Food Stock Action -->
    <record id="action_poultry_food" model="ir.actions.act_window">
        <field name="name">Food Stock</field>
        <field name="res_model">poultry.stock</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_poultry_stock_food_tree"/>
        <field name="domain">[('product_id.product_type','=','feed')]</field>
    </record>

    <!-- =========================
         Menus
    ========================= -->

    <!-- Root Menu -->
    <menuitem id="menu_poultry_stock_root" name="Poultry Stock" parent="menu_poultry"/>

    <!-- Medicine Submenu -->
    <menuitem id="menu_poultry_stock_medicine"
              name="Medicine Stock"
              parent="menu_poultry_stock_root"
              action="action_poultry_medicine"/>

    <!-- Chicken Submenu -->
    <menuitem id="menu_poultry_stock_chicken"
              name="Chicken Stock"
              parent="menu_poultry_stock_root"
              action="action_poultry_chicken"/>

    <!-- Food Submenu -->
    <menuitem id="menu_poultry_stock_food"
              name="Food Stock"
              parent="menu_poultry_stock_root"
              action="action_poultry_food"/>

</odoo>